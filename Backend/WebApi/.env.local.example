# Optional local overrides for backend-only settings.
# Copy to "Backend/WebApi/.env.local" and keep secrets there (file is gitignored).

Jwt__Key=replace_with_secret_key
Jwt__Issuer=http://localhost:7192/
Jwt__Audience=http://localhost:7192

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=example@mail.ru
SMTP_PASS=mailru_app_password
SMTP_FROM=example@mail.ru
SMTP_FROM_NAME=архив
SMTP_ENABLE_SSL=true

SMTP_CHECK_CERTIFICATE_REVOCATION=true

SYSTEM_USER_EMAIL=system@archive.local
SYSTEM_USER_NICKNAME=архив
SYSTEM_USER_PASSWORD=ChangeMe123!

Rembg__Endpoint=http://localhost:7000/api/remove

YandexAi__Endpoint=https://ai.api.cloud.yandex.net/v1/chat/completions
YandexAi__ApiKey=replace_with_api_key
YandexAi__FolderId=replace_with_folder_id
YandexAi__Model=gpt://folder/model/latest
